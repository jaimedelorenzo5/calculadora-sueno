# Copy this file to .env and fill in your values
# .env is in .gitignore — never commit real credentials

# Apify API token for SERP scraping (used by scripts/generate-post.js)
# Get yours at: https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# Anthropic API key (used by scripts/generate-post.js)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Analytics 4 Measurement ID (optional, used in CookieBanner.jsx)
# Replace the placeholder in src/components/CookieBanner.jsx
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense Publisher ID (optional, used in src/components/ads/AdSlot.jsx)
# Replace ca-pub-XXXXXXXX with your real publisher ID after AdSense approval
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
